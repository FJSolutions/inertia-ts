{
  "name": "inertia-ts",
  "description": "A library to validate and parse the environment into a state object",
  "version": "0.1.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/FJSolutions/inertia-ts"
  },
  "scripts": {
    "test": "vitest",
    "test:once": "vitest --watch=false",
    "build": "tsup",
    "pub": "pnpm build & pnpm pack --pack-destination /Projects/npm-local/",
    "clean": "bun -e \"import { $ } from 'bun'; await $`rm -rf dist`\""
  },
  "keywords": [
    "env"
  ],
  "author": "Francis Judge <fjudge7@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
